{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/main-*.js",
          "/polyfills-*.js"
        ]
      }
    },
    {
      "name": "federation-shared",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/chunk-*.js",
          "/_angular_*.js",
          "/_taiga_*.js",
          "/_codemirror_*.js",
          "/_shared_*.js",
          "/_services-*.js",
          "/rxjs*.js",
          "/fflate*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/media/**",
          "/*.webp",
          "/*.png"
        ],
        "urls": [
          "https://fonts.googleapis.com/**",
          "https://fonts.gstatic.com/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "json-configs",
      "urls": [
        "/**/assets/**/*.json"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 100,
        "maxAge": "7d",
        "timeout": "5s"
      }
    }
  ]
}
